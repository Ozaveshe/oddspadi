SPORTS_API_KEY=
API_FOOTBALL_KEY=
APISPORTS_KEY=
API_BASKETBALL_KEY=
API_TENNIS_KEY=
ODDS_API_KEY=
THE_ODDS_API_KEY=
ODDS_API_FOOTBALL_SPORT_KEY=soccer_epl
# IMPORTANT: fixtures are analysed for every league in API_FOOTBALL_LEAGUE_IDS,
# but value edge / expected value can only be computed for competitions that
# ALSO have odds here. A match with no matching odds shows the model read but
# "no value" (it isn't a model failure — there are just no prices to check).
# List up to 8 The Odds API football keys (comma-separated) to widen coverage.
# These are a PREFERENCE, not a guarantee: keys are intersected with the
# competitions The Odds API currently reports as active, and back-filled from the
# prediction league registry (src/lib/sports/footballLeagues.ts) so in-season
# competitions still get priced. Leave unset to let the registry decide — a
# hardcoded European list prices nothing at all through the summer break, since
# every top-five competition is dormant from late May to mid-August.
ODDS_API_FOOTBALL_SPORT_KEYS=
# Additional soccer markets are fetched from the single-event endpoint only.
ODDS_API_FOOTBALL_EVENT_MARKETS=btts,alternate_totals,double_chance,draw_no_bet
ODDS_API_FOOTBALL_EVENT_MARKET_LIMIT=10
ODDS_API_BASKETBALL_SPORT_KEY=basketball_nba
ODDS_API_TENNIS_SPORT_KEY=tennis_atp
ODDS_API_CACHE_TTL_MS=300000
# Historical runtime requests are expensive. Enable only for intentional paid backfills.
ODDS_API_ALLOW_HISTORICAL_RUNTIME=false
SPORTS_PROVIDER_CACHE_TTL_MS=300000
# Total upstream provider requests allowed in flight at once (protects the API
# plan rate limit during a fixture-cache miss's fan-out). Default max(6, enrichment concurrency).
SPORTS_PROVIDER_MAX_CONCURRENCY=6
# Per-request timeout (ms) for upstream provider calls. Default 4000, clamped 1000-15000.
SPORTS_PROVIDER_REQUEST_TIMEOUT_MS=4000
# Finished-match lineups/events are fetched only during intentional historical context jobs.
API_FOOTBALL_ALLOW_HISTORICAL_CONTEXT=false
# Leagues with deep analysis. Verified API-Football IDs:
# 1 World Cup, 39 EPL, 140 LaLiga, 135 SerieA, 78 Bundesliga, 61 Ligue1, 2 UCL, 3 UEL,
# 399 NPFL Nigeria, 288 PSL South Africa, 233 Egypt PL, 200 Botola Morocco,
# 570 Ghana PL, 276 Kenya FKF PL, 12 CAF Champions League, 6 AFCON, 20 CAF Confed Cup
API_FOOTBALL_LEAGUE_IDS=39,140,135,78,61,399,288,233
# How many fixtures per day get full context enrichment (lineups/injuries/events).
# Default 12, max 40. Higher = more deeply-analysed matches, more API-Football calls.
API_FOOTBALL_MAX_ENRICHED_FIXTURES=40
API_FOOTBALL_ENRICHMENT_CONCURRENCY=4
# Live xG enrichment is bounded separately: default 12 teams x 3 recent matches,
# with hard caps of 24 teams and 5 matches per team.
API_FOOTBALL_MAX_XG_TEAMS=12
API_FOOTBALL_XG_MATCHES_PER_TEAM=3
ODDSPADI_CENSUS_CACHE_TTL_MS=60000
ODDSPADI_PUBLIC_HISTORY_CACHE_TTL_MS=900000
# Affiliate links remain dormant unless both a tag and an approved market list are set.
# Supported market codes: NG,GH,KE,ZA. Confirm each operator/deal with counsel before enabling.
ODDSPADI_AFFILIATE_BET365_TAG=
ODDSPADI_AFFILIATE_BET365_MARKETS=
ODDSPADI_AFFILIATE_BETWAY_TAG=
ODDSPADI_AFFILIATE_BETWAY_MARKETS=
ODDSPADI_AFFILIATE_UNIBET_TAG=
ODDSPADI_AFFILIATE_UNIBET_MARKETS=
ODDSPADI_AFFILIATE_WILLIAMHILL_TAG=
ODDSPADI_AFFILIATE_WILLIAMHILL_MARKETS=
LIVE_SCORES_API_KEY=
NEWS_API_KEY=
NEWS_API_LANGUAGE=en
NEWS_API_PAGE_SIZE=5
WEATHER_API_KEY=
OPENWEATHER_API_KEY=
OPENAI_API_KEY=
OPENAI_DECISION_MODEL=gpt-5.1
# Model for the editorial prose pass (cheap tier is fine); blank = gpt-5-mini.
OPENAI_EDITORIAL_MODEL=
ODDSPADI_ADMIN_TOKEN=
# Generate once with `npx web-push generate-vapid-keys`; keep the private key server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@oddspadi.com
ODDSPADI_AUTONOMOUS_FIXTURE_LIMIT=12
# Number of UTC fixture dates captured per scheduled cycle (today through two days ahead).
ODDSPADI_AUTONOMOUS_HORIZON_DAYS=3
# Maximum provider-backed football feature rows stored per date.
ODDSPADI_LIVE_FEATURE_LIMIT=20
ODDSPADI_LIVE_CONTEXT_LIMIT=8
# Total OpenAI reviews across the complete scheduled date window, not per date.
ODDSPADI_AUTONOMOUS_AI_LIMIT=2
ODDSPADI_PIPELINE_SPORTS=football,basketball,tennis
ODDSPADI_PIPELINE_HORIZON_DAYS=7
ODDSPADI_ODDS_FRESHNESS_MINUTES=30
ODDSPADI_VALUE_EDGE_FLOOR=0.035
ODDSPADI_DATA_QUALITY_FLOOR=0.65
ODDSPADI_INTELLIGENCE_FULL_RUN_HOUR_UTC=2
ODDSPADI_MULTISPORT_FIXTURE_LIMIT=8
ODDSPADI_MULTISPORT_HORIZON_DAYS=2
ODDSPADI_MULTISPORT_AI_LIMIT=1
ODDSPADI_MULTISPORT_SETTLEMENT_LIMIT=100
ODDSPADI_RESULTS_SETTLEMENT_LIMIT=500
NEXT_PUBLIC_SITE_URL=https://oddspadi.com
# GA4 web-stream measurement ID. Analytics loads only after visitor consent.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# Optional Search Console HTML-tag verification token (content value only).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Optional first-party collector endpoint. It receives the same privacy-gated
# product events as GA4. Leave blank unless an owned collector is deployed.
NEXT_PUBLIC_ANALYTICS_ENDPOINT=
SUPABASE_PROJECT_REF=wncwtzqipnoqwmqlznqn
SUPABASE_URL=https://wncwtzqipnoqwmqlznqn.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://wncwtzqipnoqwmqlznqn.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Modern Supabase projects may provide an sb_secret_... backend key instead of a legacy service_role JWT.
SUPABASE_SECRET_KEY=
ODDSPADI_SUPABASE_MCP_PROJECT_REF=
