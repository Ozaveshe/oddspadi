{
  "name": "oddspadi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/run-next-build.cjs",
    "release:status": "node scripts/worktree-release.cjs status",
    "worktrees:sync": "node scripts/worktree-release.cjs sync",
    "release:verify": "npm run build && npm run typecheck && npm test && node scripts/verify-deploy-channel.cjs --release",
    "deploy:verify:manifest": "node scripts/verify-deploy-channel.cjs --manifest",
    "deploy:verify:local": "node scripts/verify-deploy-channel.cjs",
    "deploy:verify": "node scripts/verify-deploy-channel.cjs --online",
    "deploy:preview": "npm run deploy:verify && npx netlify deploy --site 3ba4bf38-60ec-4bc4-b49f-aca9495a9aa2 --context deploy-preview --message \"OddsPadi verified preview\"",
    "deploy:production": "npm run release:verify && npx netlify deploy --site 3ba4bf38-60ec-4bc4-b49f-aca9495a9aa2 --context production --prod --message \"OddsPadi verified production\"",
    "doctor": "node scripts/oddspadi-doctor.cjs",
    "setup:admin-token": "node scripts/ensure-local-admin-token.cjs",
    "start": "next start",
    "test": "vitest run",
    "training:selection-preview": "tsx scripts/preview-economic-selection-policy.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "ops:health": "node scripts/site-health.mjs",
    "ops:warm": "node scripts/warm-caches.mjs",
    "ops:editorial": "node scripts/run-editorial-sweep.mjs",
    "ops:seed-feed": "node scripts/seed-community-posts.mjs",
    "results:backfill": "node scripts/backfill-public-results.mjs",
    "player-history:prepare": "vite-node --config scripts/vite-node.config.ts scripts/prepare-player-history.ts"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "fflate": "^0.8.2",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "web-push": "^3.6.7"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@netlify/functions": "5.3.0",
    "@netlify/plugin-nextjs": "^5.15.12",
    "@types/node": "^22.15.33",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/web-push": "^3.6.4",
    "typescript": "^5.8.3",
    "vite-node": "3.2.4",
    "vitest": "^3.2.4"
  }
}
